{
  "name": "pier-x",
  "description": "Pier-X — cross-platform terminal / Git / SSH / database management tool",
  "private": true,
  "version": "0.5.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "tauri dev",
    "build": "tsc -b && vite build",
    "build:tauri": "tauri build",
    "build:debug": "tauri build --debug",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "tsc --noEmit",
    "clean": "node -e \"const {rmSync}=require('node:fs');for(const p of ['dist','src-tauri/target','src-tauri/gen/schemas']) try{rmSync(p,{recursive:true,force:true});console.log('removed',p)}catch(e){}\"",
    "bump": "node scripts/bump-version.mjs",
    "version:set": "node scripts/bump-version.mjs",
    "release:patch": "node scripts/bump-version.mjs patch --push",
    "release:minor": "node scripts/bump-version.mjs minor --push",
    "release:major": "node scripts/bump-version.mjs major --push",
    "release:package-managers": "node scripts/generate-package-manager-metadata.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.10.0",
    "sql-formatter": "^15.7.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
